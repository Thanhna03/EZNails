        "external_key": "product_group_description"
      }
    }
  },
  "gallery": {
    "type": "category",
    "block": {
      "_block_name": "gallery/hero",
      "status": true,
      "background_color": "#FFFFFF",
      "background_image": null,
      "sort": "Default"
    },
    "wrapper": "gallery",
    "page_path": "content/gallery.yml",
    "category": {
      "label": {
        "external_key": "category_title"
      }
    },
